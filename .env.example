APP_DATA_DIR=./data
LOG_LEVEL=INFO

TGBOT_TOKEN=
TGBOT_WHITELIST=
TGBOT_CONTROL_UID_WHITELIST=
TGBOT_KEYWORDS=bot,reply
TGBOT_IGNORE_KEYWORDS=
TGBOT_REPLY_TO_USER_MESSAGE=false
TGBOT_MIN_EDIT_INTERVAL_S=1.25
TGBOT_MAX_PHOTO_BYTES=3145728
TGBOT_MAX_DOCUMENT_BYTES=12582912
TGBOT_MAX_STICKER_BYTES=3145728
TGBOT_MAX_STICKER_FRAMES=4
TGBOT_MAX_INLINE_TEXT_CHARS=8000
TGBOT_MAX_VISUAL_FILE_FRAMES=10
TGBOT_LINK_PREFETCH_TIMEOUT_S=4.0
TGBOT_LINK_PREFETCH_MAX_URLS=2
TGBOT_LINK_PREFETCH_MAX_CHARS=1200

DEFAULT_PROVIDER=gemini
DEFAULT_CHAT_MODE=chat
DEFAULT_PROCESS_VISIBILITY=status
DEFAULT_RESPONSE_DELIVERY=edit
DEFAULT_STICKER_MODE=off
DEFAULT_PROMPT_INJECTION_MODE=augment
DEFAULT_TOOL_HISTORY_MODE=translated
DEFAULT_LINK_PREFETCH_MODE=off
DEFAULT_CHAT_MAX_ROUNDS=1
DEFAULT_ASSIST_MAX_ROUNDS=4
DEFAULT_AGENT_MAX_ROUNDS=6
DEFAULT_GROUP_SPONTANEOUS_REPLY_CHANCE=0
# Legacy alias still accepted: DEFAULT_GROUP_SPONTANEOUS_REPLY_IDLE_S
DEFAULT_GROUP_SPONTANEOUS_REPLY_DELAY_S=1200
DEFAULT_PRIVATE_REPLY_DELAY_S=0
DEFAULT_GROUP_REPLY_DELAY_S=5
DEFAULT_PROVIDER_RETRY_COUNT=1
DEFAULT_METADATA_INJECTION_MODE=on
DEFAULT_METADATA_TIMEZONE=UTC
DEFAULT_SYSTEM_PROMPT=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-nano
OPENAI_ENABLE_NATIVE_WEB_SEARCH=false
# 0 disables the explicit built-in web search cap.
OPENAI_NATIVE_WEB_SEARCH_MAX=1
OPENAI_REASONING_EFFORT=none
# off|on|auto|detailed|concise; "on" normalizes to "auto" for OpenAI.
OPENAI_REASONING_SUMMARY=off
OPENAI_TEXT_VERBOSITY=low
OPENAI_MAX_OUTPUT_TOKENS=4096
# 0 disables the image-count cap.
OPENAI_MAX_INPUT_IMAGES=0
# 0 disables the separate image compaction target.
OPENAI_COMPACT_TARGET_IMAGES=0
OPENAI_REQUEST_TIMEOUT_S=60.0
OPENAI_CONNECT_TIMEOUT_S=15.0

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=1.0
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
# true requests thought text in responses via thinkingConfig.includeThoughts.
GEMINI_INCLUDE_THOUGHTS=false
# Gemini 2.5 uses thinkingBudget directly. Flash supports 0 to disable thinking; Pro requires 128..32768. Use -1 for provider default/dynamic thinking.
GEMINI_THINKING_BUDGET=
# Gemini 3 native thinkingLevel: minimal|low|medium|high. Do not set together with GEMINI_THINKING_BUDGET for Gemini 3 requests.
GEMINI_THINKING_LEVEL=
GEMINI_ENABLE_NATIVE_WEB_SEARCH=false
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_MAX_INPUT_IMAGES=3600
GEMINI_COMPACT_TARGET_IMAGES=3000
GEMINI_REQUEST_TIMEOUT_S=60.0
GEMINI_CONNECT_TIMEOUT_S=15.0

SSH_EXEC_ENABLED=false
SSH_EXEC_HOST=
SSH_EXEC_PORT=22
SSH_EXEC_WORKDIR=/tmp/tgchatbot
SSH_EXEC_IDENTITY_FILE=
SSH_EXEC_CONNECT_TIMEOUT_S=10
SSH_EXEC_DEFAULT_TIMEOUT_S=20
SSH_EXEC_MAX_TOOL_TIMEOUT_S=120
SSH_EXEC_MAX_STDOUT_CHARS=16000
SSH_EXEC_MAX_STDERR_CHARS=8000
SSH_EXEC_MAX_INPUT_FILES=6
SSH_EXEC_MAX_INPUT_FILE_BYTES=8388608
SSH_EXEC_MAX_OUTPUT_FILES=5
SSH_EXEC_MAX_OUTPUT_FILE_BYTES=8388608
SSH_EXEC_SERVER_ALIVE_INTERVAL_S=30
SSH_EXEC_SERVER_ALIVE_COUNT_MAX=3
SSH_EXEC_CONTROL_PERSIST_S=600

CONTEXT_COMPACT_TRIGGER_TOKENS=300000
CONTEXT_COMPACT_TARGET_TOKENS=100000
CONTEXT_COMPACT_BATCH_TOKENS=40000
CONTEXT_COMPACT_KEEP_RECENT_RAW_TOKEN_RATIO=0.5
CONTEXT_COMPACT_TOOL_RATIO_THRESHOLD=10.0
CONTEXT_COMPACT_TOOL_MIN_TOKENS=10000
CONTEXT_COMPACT_MIN_MESSAGES=24
CONTEXT_MIN_RAW_MESSAGES_RESERVE=8
